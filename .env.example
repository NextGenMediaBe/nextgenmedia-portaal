# NextGenMedia — environment variabelen (voorbeeld, geen echte waarden)
# Kopieer naar .env.local en vul in. .env.local wordt NIET gecommit.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ClickUp-sync (alleen server-side gebruikt; nooit in client-code)
# Personal API token uit ClickUp (Settings → Apps → API Token).
CLICKUP_API_KEY=
