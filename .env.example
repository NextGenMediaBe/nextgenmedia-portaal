# NextGenMedia — environment variabelen (voorbeeld, geen echte waarden)
# Kopieer naar .env.local en vul in. .env.local wordt NIET gecommit.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ClickUp-sync (alleen server-side gebruikt; nooit in client-code)
# Personal API token uit ClickUp (Settings → Apps → API Token).
CLICKUP_API_KEY=

# E-mail Center (mails vertrekken vanuit info@nextgenmedia.be via Resend)
# RESEND_API_KEY uit resend.com; domein nextgenmedia.be moet geverifieerd zijn.
RESEND_API_KEY=
# Optioneel: afzender overschrijven (standaard "NextGenMedia <info@nextgenmedia.be>")
EMAIL_FROM=
# Publieke URL van de app, voor links in mails (bv. https://portaal.nextgenmedia.be)
NEXT_PUBLIC_SITE_URL=
# Geheim voor de cron-jobs (Vercel Cron stuurt dit als Bearer-token)
CRON_SECRET=

# Blogs: AI-generatie via Anthropic Claude (server-side)
ANTHROPIC_API_KEY=
# Optioneel: model overschrijven (default claude-sonnet-4-6)
BLOG_AI_MODEL=
# Sleutel om de Framer API key versleuteld op te slaan (AES-256-GCM). Verplicht
# voor echte encryptie at rest; zonder deze key wordt de API key onversleuteld bewaard.
BLOG_ENC_KEY=
# Framer-publicatie pas activeren ná verificatie van de framer-api integratie.
FRAMER_ENABLED=
